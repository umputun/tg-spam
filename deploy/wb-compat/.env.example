# Required Telegram settings
TELEGRAM_TOKEN=put-your-bot-token-here
TELEGRAM_GROUP=-1001234567890

# Optional but strongly recommended for admin workflows
ADMIN_GROUP=-1001234567890

# Timezone
TZ=UTC

# Optional behavior tuning
NO_SPAM_REPLY=false
SOFT_BAN=false
TRAINING=false
MESSAGE_SPAM=this is spam
MESSAGE_DRY=this is spam (dry mode)
MESSAGE_WARN=You have violated group rules. Next violation may lead to ban.
# New compatibility feature: message posted when admin unbans/restores
MESSAGE_RESTORE=message restored by admin

# Optional web UI/API
SERVER_ENABLED=true
SERVER_LISTEN=:8080

# Optional logging
LOGGER_ENABLED=true
LOGGER_FILE=/srv/logs/tg-spam.log
LOGGER_MAX_SIZE=10M

# Optional superusers (add via command in docker-compose.yml)
# Example: --super=123456789 --super=987654321
